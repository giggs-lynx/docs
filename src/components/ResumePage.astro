---
import Base from '../layouts/Base.astro';
import { resume, type Lang } from '../data/resume';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const r = resume[lang];
const htmlLang = lang === 'zh' ? 'zh-Hant' : 'en';
const description =
  lang === 'zh'
    ? '蔡勝文 (Giggs Tsai) — Principal iOS Engineer，專精車聯網、EV 充電與智慧移動。'
    : 'Sheng-Wen (Giggs) Tsai — Principal iOS Engineer specialising in Connected Vehicles, EV charging, and smart mobility.';

// telemetry-style module codes, kept in English on both locales
const modules = {
  experience: { no: '01', code: 'EXPERIENCE.LOG' },
  skills: { no: '02', code: 'SKILLS.SYS' },
  projects: { no: '03', code: 'PROJECTS.DIR' },
  education: { no: '04', code: 'EDU.REC' },
  contact: { no: '05', code: 'CONTACT.INIT' },
};
---

<Base lang={htmlLang} title={`${r.name} · ${r.title}`} description={description}>
  <!-- atmosphere -->
  <div class="glow pointer-events-none fixed inset-0 z-0"></div>
  <div class="dotgrid pointer-events-none fixed inset-0 z-0"></div>
  <div class="scanlines pointer-events-none fixed inset-0 z-40"></div>
  <div class="noise pointer-events-none fixed inset-0 z-40"></div>

  <!-- telemetry status bar -->
  <div class="relative z-30 border-b border-edge">
    <div
      class="mx-auto flex max-w-5xl items-center justify-between px-5 py-2 font-mono text-xs tracking-[0.2em] text-muted uppercase sm:px-8"
    >
      <span>GT.SYS <span class="text-volt-dim">//</span> RESUME_v3</span>
      <span class="hidden items-center gap-5 sm:flex">
        <span class="flex items-center gap-1.5">
          <span class="pulse inline-block h-1.5 w-1.5 rounded-full bg-volt"></span>
          <span class="text-volt">online</span>
        </span>
        <span>ble:connected</span>
        <span>25.03°N 121.56°E</span>
      </span>
      <span>
        <a href="/" class={lang === 'en' ? 'text-volt' : 'transition hover:text-ink'}>[EN]</a>
        <a href="/zh/" class={lang === 'zh' ? 'text-volt' : 'transition hover:text-ink'}>[中文]</a>
      </span>
    </div>
  </div>

  <!-- nav -->
  <header class="sticky top-0 z-30 border-b border-edge bg-base/85 backdrop-blur">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3 sm:px-8">
      <a href="#top" class="font-display text-base font-bold tracking-widest text-ink">
        GT<span class="text-volt">_</span>
      </a>
      <nav class="flex items-center gap-5 font-mono text-sm tracking-[0.15em] text-muted uppercase sm:gap-7">
        <a href="#experience" class="transition hover:text-volt">{r.ui.nav.experience}</a>
        <a href="#skills" class="transition hover:text-volt">{r.ui.nav.skills}</a>
        <a href="#projects" class="hidden transition hover:text-volt sm:block">{r.ui.nav.projects}</a>
        <a href="#contact" class="transition hover:text-volt">{r.ui.nav.contact}</a>
      </nav>
    </div>
  </header>

  <main id="top" class="relative z-10 mx-auto max-w-5xl px-5 sm:px-8">
    <!-- hero -->
    <section class="relative pt-20 pb-14 sm:pt-28 sm:pb-20">
      <span
        aria-hidden="true"
        class="ghost pointer-events-none absolute -top-2 right-0 hidden font-display text-[11rem] leading-none font-bold select-none lg:block"
      >
        11Y
      </span>

      <p class="reveal font-mono text-sm tracking-[0.3em] text-volt uppercase" style="animation-delay: 0ms">
        &gt; {r.title.replaceAll(' ', '_')}<span class="cursor">▌</span>
      </p>
      <h1
        class="reveal mt-5 max-w-3xl font-display text-4xl leading-[1.05] font-bold tracking-tight text-white uppercase sm:text-6xl"
        style="animation-delay: 90ms"
      >
        {r.name}
      </h1>
      <p class="reveal mt-4 font-mono text-sm tracking-[0.15em] text-muted uppercase" style="animation-delay: 180ms">
        {r.location}
      </p>
      <p class="reveal mt-7 max-w-2xl text-base leading-relaxed text-ink/85 sm:text-lg" style="animation-delay: 270ms">
        {r.summary}
      </p>

      <!-- instrument readouts -->
      <div class="reveal mt-14" style="animation-delay: 380ms">
        <div class="ticks h-1.5 w-full"></div>
        <dl class="grid grid-cols-2 border border-edge bg-panel/60 sm:grid-cols-4">
          {
            r.stats.map((s, i) => (
              <div class={`px-5 py-5 ${i > 0 ? 'border-l border-edge max-sm:[&:nth-child(3)]:border-l-0' : ''} ${i >= 2 ? 'max-sm:border-t max-sm:border-edge' : ''}`}>
                <dd class="font-display text-3xl font-bold text-volt sm:text-4xl">{s.value}</dd>
                <dt class="mt-1 font-mono text-xs tracking-[0.15em] text-muted uppercase">{s.label}</dt>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <!-- experience -->
    <section id="experience" class="relative scroll-mt-20 py-14">
      <span aria-hidden="true" class="ghost pointer-events-none absolute top-4 right-0 font-display text-8xl font-bold select-none">
        {modules.experience.no}
      </span>
      <p class="font-mono text-sm tracking-[0.25em] text-volt uppercase">
        [{modules.experience.no}] <span class="text-muted">// {modules.experience.code}</span>
      </p>
      <h2 class="mt-2 font-display text-3xl font-bold text-white uppercase">{r.ui.sections.experience}</h2>

      <div class="mt-10 space-y-14">
        {
          r.experience.map((job) => (
            <article class="relative border-l border-edge pl-6 sm:pl-9">
              <span class="absolute top-2 -left-[4.5px] h-2 w-2 rotate-45 bg-volt shadow-[0_0_14px_rgba(198,244,50,0.9)]" />
              <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
                <h3 class="font-display text-xl font-bold tracking-wide text-white uppercase">{job.company}</h3>
                <p class="font-mono text-sm tracking-[0.15em] text-signal">{job.period}</p>
              </div>
              <p class="mt-1.5 font-mono text-sm tracking-wide text-volt">
                {job.role} <span class="text-muted">· {job.domain}</span>
              </p>
              {job.intro && <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink/80">{job.intro}</p>}

              {job.projects && (
                <div class="mt-6 space-y-5">
                  {job.projects.map((p) => (
                    <div class="corner-frame bg-panel/50 p-5 sm:p-6">
                      <div class="flex flex-wrap items-baseline justify-between gap-2">
                        <h4 class="font-display text-base font-semibold tracking-wide text-white">{p.name}</h4>
                        {p.link && (
                          <a
                            href={p.link.url}
                            target="_blank"
                            rel="noopener"
                            class="font-mono text-sm tracking-wider text-volt uppercase transition hover:text-white"
                          >
                            {p.link.label} ↗
                          </a>
                        )}
                      </div>
                      <ul class="mt-4 space-y-2.5">
                        {p.points.map((pt) => (
                          <li class="flex gap-3 text-base leading-relaxed text-ink/80">
                            <span class="mt-px shrink-0 font-mono text-xs text-volt-dim">▸</span>
                            <span>{pt}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  ))}
                </div>
              )}

              {job.points && (
                <ul class="mt-5 max-w-3xl space-y-2.5">
                  {job.points.map((pt) => (
                    <li class="flex gap-3 text-base leading-relaxed text-ink/80">
                      <span class="mt-px shrink-0 font-mono text-xs text-volt-dim">▸</span>
                      <span>{pt}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div class="mt-5 flex flex-wrap gap-x-3 gap-y-1.5 font-mono text-xs tracking-wider text-muted uppercase">
                {job.tags.map((t) => (
                  <span class="transition hover:text-volt">[{t}]</span>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- skills -->
    <section id="skills" class="relative scroll-mt-20 py-14">
      <span aria-hidden="true" class="ghost pointer-events-none absolute top-4 right-0 font-display text-8xl font-bold select-none">
        {modules.skills.no}
      </span>
      <p class="font-mono text-sm tracking-[0.25em] text-volt uppercase">
        [{modules.skills.no}] <span class="text-muted">// {modules.skills.code}</span>
      </p>
      <h2 class="mt-2 font-display text-3xl font-bold text-white uppercase">{r.ui.sections.skills}</h2>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {
          r.skills.map((group) => (
            <div class="corner-frame bg-panel/50 p-5 sm:p-6">
              <h3 class="font-mono text-sm font-medium tracking-[0.2em] text-volt uppercase">{group.category}</h3>
              <div class="mt-4 flex flex-wrap gap-2">
                {group.items.map((item) => (
                  <span class="border border-edge bg-base px-2.5 py-1 text-sm text-ink/80 transition hover:border-volt-dim">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <!-- projects -->
    <section id="projects" class="relative scroll-mt-20 py-14">
      <span aria-hidden="true" class="ghost pointer-events-none absolute top-4 right-0 font-display text-8xl font-bold select-none">
        {modules.projects.no}
      </span>
      <p class="font-mono text-sm tracking-[0.25em] text-volt uppercase">
        [{modules.projects.no}] <span class="text-muted">// {modules.projects.code}</span>
      </p>
      <h2 class="mt-2 font-display text-3xl font-bold text-white uppercase">{r.ui.sections.projects}</h2>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {
          r.highlights.map((p, i) => (
            <a
              href={p.link}
              target="_blank"
              rel="noopener"
              class="group corner-frame relative bg-panel/50 p-6 transition duration-200 hover:-translate-y-1 hover:bg-panel"
            >
              <span class="ghost font-display text-4xl font-bold">0{i + 1}</span>
              <h3 class="mt-4 font-display text-base font-semibold tracking-wide text-white transition group-hover:text-volt">
                {p.name}
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-ink/70">{p.desc}</p>
              <p class="mt-5 font-mono text-sm tracking-wider text-volt uppercase">{p.linkLabel} ↗</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- education -->
    <section class="relative py-14">
      <p class="font-mono text-sm tracking-[0.25em] text-volt uppercase">
        [{modules.education.no}] <span class="text-muted">// {modules.education.code}</span>
      </p>
      <h2 class="mt-2 font-display text-3xl font-bold text-white uppercase">{r.ui.sections.education}</h2>
      <div class="mt-7 space-y-3">
        {
          r.education.map((e) => (
            <div class="flex flex-wrap items-baseline justify-between gap-2 border-l border-edge pl-6 sm:pl-9">
              <p class="text-base text-ink/85">
                <span class="font-display font-semibold text-white">{e.school}</span>
                <span class="text-muted"> — {e.degree}</span>
              </p>
              <p class="font-mono text-sm tracking-[0.15em] text-signal">{e.period}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- contact -->
    <section id="contact" class="scroll-mt-20 py-16">
      <div class="corner-frame bg-panel/50 px-6 py-12 text-center sm:px-12 sm:py-16">
        <p class="font-mono text-sm tracking-[0.3em] text-volt uppercase">
          [{modules.contact.no}] // {modules.contact.code}
        </p>
        <h2 class="mt-5 font-display text-2xl font-bold text-white uppercase sm:text-3xl">
          {r.ui.contactCta}
        </h2>
        <p class="mt-3 font-mono text-sm tracking-wide text-muted">{r.ui.openTo}</p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
          <a
            href={`mailto:${r.contact.email}`}
            class="bg-volt px-6 py-3 font-mono text-sm font-medium tracking-[0.15em] text-[#08090b] uppercase transition hover:shadow-[0_0_24px_rgba(198,244,50,0.45)]"
          >
            {r.contact.email}
          </a>
          <a
            href={`tel:${r.contact.phone.replace(/[^+\d]/g, '')}`}
            class="border border-edge px-6 py-3 font-mono text-sm tracking-[0.15em] text-ink/80 transition hover:border-volt hover:text-volt"
          >
            {r.contact.phone}
          </a>
          <a
            href={r.contact.github}
            target="_blank"
            rel="noopener"
            class="border border-edge px-6 py-3 font-mono text-sm tracking-[0.15em] text-ink/80 uppercase transition hover:border-volt hover:text-volt"
          >
            GitHub ↗
          </a>
        </div>
      </div>
      <p class="py-10 text-center font-mono text-xs tracking-[0.2em] text-muted/60 uppercase">
        © 2026 Giggs Tsai · sys.shutdown_
      </p>
    </section>
  </main>
</Base>
