---
import '../styles/global.css';

interface Props {
  lang: 'en' | 'zh-Hant';
  title: string;
  description: string;
}

const { lang, title, description } = Astro.props;
const fontFamilies = [
  'family=Chakra+Petch:wght@500;600;700',
  'family=IBM+Plex+Sans:wght@400;500;600',
  'family=IBM+Plex+Mono:wght@400;500',
];
if (lang === 'zh-Hant') {
  fontFamilies.push('family=Noto+Sans+TC:wght@400;500;700');
}
const fontHref = `https://fonts.googleapis.com/css2?${fontFamilies.join('&')}&display=swap`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="profile" />
    <meta name="theme-color" content="#08090b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href={fontHref} rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
